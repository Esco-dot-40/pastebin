# Database
DATABASE_URL=postgresql://username:password@localhost:5432/pastebin

# --------------------------------------------
# DISCORD OAUTH CONFIGURATION
# --------------------------------------------
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# --------------------------------------------
# GOOGLE AUTH (FIREBASE)
# --------------------------------------------
# Frontend config is in index.html/view.html
# Backend verification can be added to auth.js

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Admin Authentication
# Generate hash with: node server/generate-password.js
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here
SESSION_SECRET=your-random-secret-here

# Frontend URLs (update these when deploying)
ADMIN_URL=http://localhost:3000/admin
PUBLIC_URL=http://localhost:3000/public

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
