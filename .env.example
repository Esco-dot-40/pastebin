# Database
DATABASE_URL=postgresql://username:password@localhost:5432/pastebin

# --------------------------------------------
# DISCORD OAUTH CONFIGURATION
# --------------------------------------------
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=https://veroe.space/api/auth/discord/callback

# --------------------------------------------
# FIREBASE CONFIGURATION (FOR GOOGLE AUTH)
# --------------------------------------------
# Get these from Firebase Console -> Project Settings -> General -> Your Apps -> Config
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Admin Authentication
# Generate hash with: node server/generate-password.js
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here
SESSION_SECRET=your-random-secret-here

# Frontend URLs (update these when deploying)
ADMIN_URL=https://veroe.space/admin
PUBLIC_URL=https://veroe.space/public

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
